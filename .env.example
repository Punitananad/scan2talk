# Django Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/gateway_platform

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Platform Configuration
PLATFORM_DOMAIN=localhost:8000
PLATFORM_NAME=Gateway Platform
MAX_GATEWAYS_PER_USER=100

# Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Twilio Configuration (for SMS and IVR)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Business API Configuration
WHATSAPP_BUSINESS_API_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=

# SMSCountry OTP Configuration (AuthKey-based, NO SID)
SMSCOUNTRY_AUTH_KEY=your_auth_key_here
SMSCOUNTRY_AUTH_TOKEN=your_auth_token_here

# SparkTG Call Masking Configuration (Telephony Cloud - Spartan)
SPARKTG_USERNAME=-
SPARKTG_PASSWORD=-
SPARKTG_SID=-
SPARKTG_DID_NUMBER=-

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# CORS Configuration (for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security Settings (for production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
